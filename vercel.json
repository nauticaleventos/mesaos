{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron-generar-recetas",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/cron-recordatorio-domingo",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron-alertas-preparacion",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)\\.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    },
    {
      "source": "/assets/(.*)\\.css",
      "headers": [{ "key": "Content-Type", "value": "text/css; charset=utf-8" }]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
